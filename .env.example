# Database Settings
DATABASE_URL=postgresql://postgres:postgres_secure_pwd@db:5432/tenderai

# Redis settings (celery & event pub/sub)
REDIS_URL=redis://redis:6379/0

# Security (JWT Auth)
JWT_SECRET_KEY=super_secure_jwt_token_secret_key_change_in_production_123456
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# LLM Providers (Required for AI Agents)
# Gemini API Key (Primary Agent Brain)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
# Optional OpenAI Key (Fallback Agent Brain)
OPENAI_API_KEY=

# Storage settings
UPLOAD_DIR=/app/uploads

# Port configurations
BACKEND_PORT=8000
FRONTEND_PORT=5173
